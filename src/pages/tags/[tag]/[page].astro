---
import Layout from "../../../components/Layout.astro";
import Heading from "../../../components/Heading.astro";
import { getPublishedPosts } from "../../../lib/posts";

export async function getStaticPaths() {
  const TAG_PAGE_SIZE = 9;
  const allPosts = await getPublishedPosts();
  const tags = [...new Set(allPosts.flatMap((p) => p.data.tags))];

  const paths: { params: { tag: string; page: string }; props: { tag: string; posts: typeof allPosts; totalPages: number; currentPage: number } }[] = [];

  for (const tag of tags) {
    const tagPosts = allPosts.filter((p) => p.data.tags.includes(tag));
    const totalPages = Math.ceil(tagPosts.length / TAG_PAGE_SIZE);
    for (let page = 2; page <= totalPages; page++) {
      paths.push({
        params: { tag, page: String(page) },
        props: {
          tag,
          posts: tagPosts.slice((page - 1) * TAG_PAGE_SIZE, page * TAG_PAGE_SIZE),
          totalPages,
          currentPage: page,
        },
      });
    }
  }

  return paths;
}

const { tag, posts, totalPages, currentPage } = Astro.props;
---

<Layout title={`標籤「${tag}」— WAHSUNの自留地`} description={`所有標籤為「${tag}」的文章 — 第 ${currentPage} 頁。`}>
  <section class="tag-detail">
    <a href="/tags" class="breadcrumb">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3 L5 7 L9 11"/></svg>
      所有標籤
    </a>

    <header class="tag-header">
      <a href={`/tags/${tag}`} class="tag-title-link">
        <h1 class="tag-title">{tag}</h1>
      </a>
      <p class="tag-meta">第 {currentPage} 頁</p>
    </header>

    <ul class="post-list">
      {posts.map((post) => {
        const formattedDate = post.data.date.toLocaleDateString("en-US", {
          year: "numeric",
          month: "long",
          day: "numeric",
        });
        return (
          <li class="post-item ink-border">
            <a href={`/posts/${post.id}`}>
              <time datetime={post.data.date.toISOString()}>{formattedDate}</time>
              <span class="post-title">{post.data.title}</span>
              <span class="post-description">{post.data.description}</span>
            </a>
          </li>
        );
      })}
    </ul>

    <nav class="pagination" aria-label="Pagination">
      {currentPage > 1 && (
        <a href={currentPage === 2 ? `/tags/${tag}` : `/tags/${tag}/${currentPage - 1}`} class="pagination-link">
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2 L4 6 L8 10"/></svg>
          較新文章
        </a>
      )}
      <span class="pagination-info">第 {currentPage} 頁，共 {totalPages} 頁</span>
      {currentPage < totalPages && (
        <a href={`/tags/${tag}/${currentPage + 1}`} class="pagination-link">
          較舊文章
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"><path d="M4 2 L8 6 L4 10"/></svg>
        </a>
      )}
    </nav>
  </section>
</Layout>

<style>
  .tag-detail { padding: 2rem 0 4rem; }

  .breadcrumb {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--text-tertiary);
    text-decoration: none;
    margin-bottom: 1.25rem;
    transition: color 0.2s;
  }
  .breadcrumb:hover { color: var(--text); }

  .tag-header { margin-bottom: 1.75rem; }
  .tag-title-link { text-decoration: none; color: var(--text); }
  .tag-title {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin-bottom: 0.5rem;
  }
  .tag-meta {
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    color: var(--text-tertiary);
  }

  /* ─── Post List ──────────────────────────── */
  .post-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* ─── Post Item ──────────────────────────── */
  .post-item {
    padding: 1.25rem 1.5rem;
    background: var(--surface);
    border-radius: var(--radius-md);
    transition: border-color 0.3s, box-shadow 0.3s, transform 0.2s;
  }
  .post-item:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }
  .post-item a {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    text-decoration: none;
    color: var(--text);
  }
  .post-item time {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--text-tertiary);
  }
  .post-title {
    font-family: var(--font-heading);
    font-size: 0.9375rem;
    font-weight: 600;
    line-height: 1.35;
    transition: color 0.2s;
  }
  .post-item a:hover .post-title {
    background: var(--gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .post-description {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ─── Pagination ────────────────────────── */
  .pagination {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }
  .pagination-info {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--text-tertiary);
  }
  .pagination-link {
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.375rem;
    transition: color 0.2s;
  }
  .pagination-link:hover { color: var(--accent); }

  @media (max-width: 600px) {
    .tag-title { font-size: 1.25rem; }
    .post-item { padding: 1rem; }
  }
</style>
