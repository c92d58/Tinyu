const { tag, posts, totalPages, totalPosts } = Astro.props;
const group = GROUP_MAP[tag] || null;
---

<Layout title={`標籤「${tag}」— WAHSUNの自留地`} description={`所有標籤為「${tag}」的 ${totalPosts} 篇文章。`}>
  <section class="tag-detail">
    <!-- Breadcrumb -->
    <a href="/tags" class="breadcrumb">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3 L5 7 L9 11"/></svg>
      所有標籤
    </a>

    <!-- Tag Header -->
    <header class="tag-header">
      {group && (
        <span class="tag-group-badge" style={`--badge-color:${group.color}`}>
          <span class="badge-dot"></span>
          {group.name}
        </span>
      )}
      <h1 class="tag-title">{tag}</h1>
      <p class="tag-meta">
        <span class="tag-count">{totalPosts} 篇文章</span>
      </p>
    </header>

    <!-- Post List -->
    <ul class="post-list">
      {posts.map((post) => {
        const formattedDate = post.data.date.toLocaleDateString("en-US", {
          year: "numeric",
          month: "long",
          day: "numeric",
        });
        return (
          <li class="post-item ink-border">
            <a href={`/posts/${post.id}`}>
              <time datetime={post.data.date.toISOString()}>{formattedDate}</time>
              <span class="post-title">{post.data.title}</span>
              <span class="post-description">{post.data.description}</span>
            </a>
          </li>
        );
      })}
    </ul>

    <!-- Pagination -->
    {totalPages > 1 && (
      <nav class="pagination" aria-label="Pagination">
        <span class="pagination-info">第 1 頁，共 {totalPages} 頁</span>
        <a href={`/tags/${tag}/2`} class="pagination-link">
          較舊文章
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"><path d="M4 2 L8 6 L4 10"/></svg>
        </a>
      </nav>
    )}
  </section>
</Layout>

<style>
  .tag-detail {
    max-width: var(--width-content);
    padding-top: 0.5rem;
  }

  /* ─── Breadcrumb ────────────────────────── */
  .breadcrumb {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    color: var(--color-text-tertiary);
    text-decoration: none;
    margin-bottom: 1.25rem;
    padding: 0.15rem 0.5rem;
    border: 1px solid var(--color-border);
    border-radius: 100px;
    transition: all 0.2s ease;
  }

  .breadcrumb:hover {
    color: var(--color-text);
    border-color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 6%, transparent);
  }

  /* ─── Tag Header ────────────────────────── */
  .tag-header {
    margin-bottom: 1.75rem;
    animation: fadeUp 0.5s ease both;
  }

  .tag-group-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-heading);
    font-size: 0.6875rem;
    color: var(--badge-color);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
    padding: 0.25rem 0.75rem;
    border: 1px solid color-mix(in srgb, var(--badge-color) 25%, transparent);
    border-radius: 100px;
    background: color-mix(in srgb, var(--badge-color) 6%, transparent);
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--badge-color);
  }

  .tag-title {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--color-text);
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin-bottom: 0.5rem;
  }

  .tag-meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .tag-count {
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    color: var(--color-text-tertiary);
  }

  /* ─── Post List ─────────────────────────── */
  .post-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    animation: fadeUp 0.5s ease 0.1s both;
  }

  .post-item {
    padding: 1.25rem 1.5rem;
    background: var(--color-surface);
    border-radius: var(--radius-md);
    transition: border-color 0.35s ease, box-shadow 0.35s ease, transform 0.3s ease;
  }

  .post-item:hover {
    border-color: var(--color-accent);
    box-shadow:
      0 0 0 1px var(--color-ink-light),
      0 4px 20px var(--color-ink-medium);
    transform: translateY(-2px);
  }

  .post-item a {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    text-decoration: none;
    color: var(--color-text);
  }

  .post-item time {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
  }

  .post-title {
    font-family: var(--font-heading);
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.3;
    transition: color 0.2s ease;
  }

  .post-item a:hover .post-title {
    color: var(--color-text-secondary);
  }

  .post-description {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  /* ─── Pagination ────────────────────────── */
  .pagination {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: var(--space-xl);
    padding-top: var(--space-lg);
    position: relative;
  }

  .pagination::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, var(--color-border) 0%, transparent 80%);
  }

  .pagination-link {
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.2s ease;
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .pagination-link:hover {
    color: var(--color-text);
  }

  .pagination-info {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
  }

  /* ─── Responsive ────────────────────────── */
  @media (max-width: 600px) {
    .tag-title { font-size: 1.25rem; }
    .post-item { padding: var(--space-md); }
  }
</style>
