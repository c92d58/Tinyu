---
import Layout from "../../../components/Layout.astro";
import Heading from "../../../components/Heading.astro";
import { getPublishedPosts } from "../../../lib/posts";

export async function getStaticPaths() {
  const TAG_PAGE_SIZE = 10;
  const allPosts = await getPublishedPosts();
  const tags = [...new Set(allPosts.flatMap((p) => p.data.tags))];
  return tags.map((tag) => {
    const tagPosts = allPosts.filter((p) => p.data.tags.includes(tag));
    return {
      params: { tag },
      props: {
        tag,
        posts: tagPosts.slice(0, TAG_PAGE_SIZE),
        totalPages: Math.ceil(tagPosts.length / TAG_PAGE_SIZE),
        totalPosts: tagPosts.length,
      },
    };
  });
}

