---
import Layout from "../../components/Layout.astro";
import Heading from "../../components/Heading.astro";
import { getPublishedPosts } from "../../lib/posts";
import type { GetStaticPathsOptions } from "astro";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const posts = await getPublishedPosts();
  const pages = paginate(posts, { pageSize: 9 });
  return pages.filter((p) => p.params.page !== '1');
}

const { page } = Astro.props;
---

<Layout title={`第 ${page.currentPage} 頁 — WAHSUNの自留地`}>
  <section class="home">
    <header class="page-header">
      <h1 class="page-title">所有文章<span class="page-sub">· 第 {page.currentPage} 頁</span></h1>
      <p class="page-tagline">共 {page.lastPage} 頁 · 持續書寫中</p>
    </header>

    <ul class="post-list">
      {page.data.map((post, index) => {
        const formattedDate = post.data.date.toLocaleDateString("en-US", {
          year: "numeric",
          month: "long",
          day: "numeric",
        });
        return (
          <li class="post-item ink-border animate-fade-up">
            <a href={`/posts/${post.id}`}>
              <span class="post-meta">
                <span class="post-number">#{(page.start + index).toString().padStart(2, '0')}</span>
                <time datetime={post.data.date.toISOString()}>{formattedDate}</time>
              </span>
              <span class="post-title">{post.data.title}</span>
              <span class="post-description">{post.data.description}</span>
            </a>
          </li>
        );
      })}
    </ul>

    <nav class="pagination" aria-label="Pagination">
      {page.url.prev && (
        <a href={page.currentPage === 2 ? "/" : page.url.prev} class="pagination-link">
          <span class="pagination-arrow">←</span>
          較新文章
        </a>
      )}
      <span class="pagination-info">第 {page.currentPage} 頁，共 {page.lastPage} 頁</span>
      {page.url.next && (
        <a href={page.url.next} class="pagination-link">
          較舊文章
          <span class="pagination-arrow">→</span>
        </a>
      )}
    </nav>
  </section>
</Layout>

<style>
  .home { padding: 2rem 0 4rem; }

  .page-header {
    text-align: center;
    margin-bottom: 2rem;
  }
  .page-title {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 0.5rem;
  }
  .page-sub {
    font-weight: 400;
    font-size: 0.7em;
    color: var(--text-tertiary);
  }
  .page-tagline {
    font-size: 0.875rem;
    color: var(--text-tertiary);
    margin-top: 0.25rem;
    font-style: italic;
  }

  /* ─── Post List ──────────────────────────── */
  .post-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  /* ─── Post Item ──────────────────────────── */
  .post-item {
    padding: 1.25rem;
    background: var(--surface);
    transition: border-color 0.3s, box-shadow 0.3s, transform 0.2s;
  }
  .post-item:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }
  .post-item a {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    text-decoration: none;
    color: var(--text);
  }
  .post-item time {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--text-tertiary);
  }
  .post-title {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.35;
    transition: color 0.2s;
  }
  .post-item a:hover .post-title {
    background: var(--gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .post-description {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ─── Pagination ────────────────────────── */
  .pagination {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }
  .pagination-info {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--text-tertiary);
  }
  .pagination-link {
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.375rem;
    transition: color 0.2s;
  }
  .pagination-link:hover { color: var(--accent); }
  .pagination-arrow { transition: transform 0.2s; }
  .pagination-link:hover .pagination-arrow { transform: translateX(2px); }
  .pagination-link:first-child:hover .pagination-arrow { transform: translateX(-2px); }

  @media (max-width: 600px) {
    .page-title { font-size: 1.5rem; }
    .post-item { padding: 1rem; }
  }
</style>
