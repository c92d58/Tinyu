---
import Layout from "../components/Layout.astro";
import Heading from "../components/Heading.astro";
import { getPublishedPosts } from "../lib/posts";

const allPosts = await getPublishedPosts();
const featured = allPosts[0];
const restPosts = allPosts.slice(1);
const totalPages = Math.ceil(allPosts.length / 9);
---

<Layout title="聽雨">
  <section class="home">

    <!-- ─── Hero ─────────────────────────────── -->
    <header class="hero">
      <p class="hero-label animate-fade-up">個人部落格</p>
      <h1 class="hero-title animate-fade-up delay-1">
        <span class="hero-gradient">聽雨</span>
      </h1>
      <p class="hero-sub animate-fade-up delay-2">在雨聲中，讀懂人性的溫度</p>
      <div class="hero-underline"></div>
      <p class="hero-desc animate-fade-up delay-3">
        關於閱讀、思考與生活的筆記。一個人在試圖穿透自己頭腦中的迷霧時，留下的文字。
      </p>
      <div class="hero-stats animate-fade-up delay-4">
        <span>{allPosts.length} 篇文章</span>
        <span class="hero-dot">·</span>
        <span>持續書寫中</span>
      </div>
    </header>

    <!-- ─── Featured Post ─────────────────────── -->
    {featured && (
      <article class="featured card animate-fade-up delay-3">
        <a href={`/posts/${featured.id}`} class="featured-link">
          <span class="tag">最新文章</span>
          <h2 class="featured-title">{featured.data.title}</h2>
          <p class="featured-desc">{featured.data.description}</p>
          <time class="featured-date" datetime={featured.data.date.toISOString()}>
            {featured.data.date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
          </time>
        </a>
      </article>
    )}

    <!-- ─── All Posts ─────────────────────────── -->
    <div class="section-label-wrap">
      <span class="section-label">所有文章</span>
    </div>

    <ul class="post-list">
      {
        restPosts.map((post, i) => {
          const formattedDate = post.data.date.toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
            day: "numeric",
          });
          return (
            <li class="post-item ink-border animate-fade-up delay-{Math.min(i + 1, 6)}" data-index={i + 2}>
              <a href={`/posts/${post.id}`}>
                <span class="post-meta">
                  <span class="post-number">#{(i + 2).toString().padStart(2, '0')}</span>
                  <time datetime={post.data.date.toISOString()}>{formattedDate}</time>
                </span>
                <span class="post-title">{post.data.title}</span>
                <span class="post-description">{post.data.description}</span>
              </a>
            </li>
          );
        })
      }
    </ul>

    {totalPages > 1 && (
      <nav class="pagination" aria-label="Pagination">
        <span class="pagination-info">第 1 頁，共 {totalPages} 頁</span>
        <a href="/page/2" class="pagination-link">
          較舊文章
          <span class="pagination-arrow">→</span>
        </a>
      </nav>
    )}
  </section>
</Layout>

<style>
  .home { padding: 2rem 0 4rem; }

  /* ─── Hero ──────────────────────────────── */
  .hero {
    text-align: center;
    padding: 3rem 0 2.5rem;
    position: relative;
  }
  .hero-label {
    font-family: var(--font-heading);
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--accent);
    margin-bottom: 1rem;
  }
  .hero-title {
    font-family: var(--font-heading);
    font-size: 3rem;
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 0.75rem;
  }
  .hero-gradient {
    background: var(--gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-sub {
    font-size: 1rem;
    color: var(--text-secondary);
    font-style: italic;
    margin-bottom: 1.25rem;
  }
  .hero-underline {
    width: 40px;
    height: 3px;
    background: var(--gradient);
    border-radius: 2px;
    margin: 0 auto 1.25rem;
  }
  .hero-desc {
    font-size: 0.9375rem;
    color: var(--text-tertiary);
    max-width: 500px;
    margin: 0 auto 1rem;
    line-height: 1.6;
  }
  .hero-stats {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--text-tertiary);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }
  .hero-dot { color: var(--accent); }

  /* ─── Featured Post ──────────────────────── */
  .featured { margin-bottom: 2rem; }
  .featured-link {
    display: block;
    padding: 1.5rem;
    text-decoration: none;
    color: var(--text);
  }
  .featured:hover .featured-title {
    background: var(--gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .featured-title {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.35;
    margin-top: 0.75rem;
    transition: color 0.3s;
  }
  .featured-desc {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-top: 0.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .featured-date {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--text-tertiary);
    display: block;
    margin-top: 0.75rem;
  }

  /* ─── All Posts label ────────────────────── */
  .section-label-wrap {
    margin: 2.5rem 0 1.25rem;
  }

  /* ─── Post List ──────────────────────────── */
  .post-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  /* ─── Post Item ──────────────────────────── */
  .post-item {
    padding: 1.25rem;
    background: var(--surface);
    transition: border-color 0.3s, box-shadow 0.3s, transform 0.2s;
  }
  .post-item:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }
  .post-item a {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    text-decoration: none;
    color: var(--text);
  }
  .post-item time {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--text-tertiary);
  }
  .post-title {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.35;
    transition: color 0.2s;
  }
  .post-item a:hover .post-title {
    background: var(--gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .post-description {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ─── Pagination ────────────────────────── */
  .pagination {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }
  .pagination-info {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--text-tertiary);
  }
  .pagination-link {
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.375rem;
    transition: color 0.2s;
  }
  .pagination-link:hover { color: var(--accent); }
  .pagination-arrow {
    transition: transform 0.2s;
  }
  .pagination-link:hover .pagination-arrow {
    transform: translateX(2px);
  }

  /* ─── Responsive ────────────────────────── */
  @media (max-width: 600px) {
    .hero { padding: 2rem 0 1.5rem; }
    .hero-title { font-size: 2.25rem; }
    .featured-link { padding: 1.25rem; }
    .post-item { padding: 1rem; }
  }
</style>
