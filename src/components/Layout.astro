---
import Nav from "./Nav.astro";
import Footer from "./Footer.astro";
import BackToTop from "./BackToTop.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  ogType?: "website" | "article";
  ogImage?: string;
}

const {
  title,
  description = "在雨聲中，讀懂人性的溫度。",
  ogType = "website",
  ogImage = "/og/default.png",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const googleVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;
const plausibleDomain = import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN;
const fathomSiteId = import.meta.env.PUBLIC_FATHOM_SITE_ID;
const ogImageAbsolute = new URL(ogImage, Astro.site).href;
---

<!doctype html>
<html lang="zh-TW">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" media="(prefers-color-scheme: dark)" />
    <link rel="apple-touch-icon" href="/logo-mark.svg" />
    <meta name="apple-mobile-web-app-title" content="聽雨" />
    <meta name="theme-color" content="#f7f3eb" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#121014" media="(prefers-color-scheme: dark)" />
    {googleVerification && <meta name="google-site-verification" content={googleVerification} />}
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL.href} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:site_name" content="聽雨" />
    <meta property="og:image" content={ogImageAbsolute} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <slot name="head" />

    <link rel="alternate" type="application/rss+xml" title="聽雨" href="/rss.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Newsreader:ital,wght@0,400;0,500;0,600;1,400;1,500&family=JetBrains+Mono:wght@400&family=Noto+Serif+SC:wght@400;500;600;700&family=Noto+Sans+SC:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <!-- Analytics -->
    {plausibleDomain && (
      <script defer data-domain={plausibleDomain} src="https://plausible.io/js/script.js" />
    )}
    {fathomSiteId && (
      <script src="https://cdn.usefathom.com/script.js" data-site={fathomSiteId} defer />
    )}
  </head>
  <body>
    <div class="page">
      <Nav />
      <main id="main-content">
        <slot />
      </main>
      <Footer />
    </div>
    <BackToTop />

    <!-- Reading progress indicator -->
    <div id="reading-progress" class="reading-progress" aria-hidden="true"></div>
    <script>
      const progress = document.getElementById("reading-progress");
      if (progress) {
        window.addEventListener("scroll", () => {
          const scrollTop = window.scrollY;
          const docHeight = document.documentElement.scrollHeight - window.innerHeight;
          const pct = docHeight > 0 ? Math.min(scrollTop / docHeight, 1) : 0;
          progress.style.transform = `scaleX(${pct})`;
        }, { passive: true });
      }
    </script>
  </body>
</html>

<style>
  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background: linear-gradient(90deg, var(--color-accent), transparent);
    transform: scaleX(0);
    transform-origin: left;
    z-index: 100;
    pointer-events: none;
    transition: opacity 0.3s ease;
    opacity: 0;
  }
  .reading-progress {
    opacity: 1;
  }

  .page {
    max-width: var(--width-wide);
    margin: 0 auto;
    padding: 0 var(--space-lg);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  main {
    flex: 1;
  }

  @media (max-width: 600px) {
    .page { padding: 0 var(--space-md); }
  }
</style>
