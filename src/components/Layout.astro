---
import Nav from "./Nav.astro";
import Footer from "./Footer.astro";
import BackToTop from "./BackToTop.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  ogType?: "website" | "article";
  ogImage?: string;
}

const {
  title,
  description = "閱讀、思考與生活的筆記。一個人在試圖穿透自己頭腦中的迷霧時，留下的文字。",
  ogType = "website",
  ogImage = "/og/default.png",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const googleVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;
const plausibleDomain = import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN;
const fathomSiteId = import.meta.env.PUBLIC_FATHOM_SITE_ID;
const ogImageAbsolute = new URL(ogImage, Astro.site).href;
---

<!doctype html>
<html lang="zh-TW">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" media="(prefers-color-scheme: dark)" />
    <link rel="apple-touch-icon" href="/logo-mark.svg" />
    <meta name="apple-mobile-web-app-title" content="WAHSUNの自留地" />
    <meta name="theme-color" content="#f7f3eb" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#121014" media="(prefers-color-scheme: dark)" />
    {googleVerification && <meta name="google-site-verification" content={googleVerification} />}
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL.href} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:site_name" content="WAHSUNの自留地" />
    <meta property="og:image" content={ogImageAbsolute} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <slot name="head" />

    <link rel="alternate" type="application/rss+xml" title="WAHSUNの自留地" href="/rss.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Newsreader:ital,wght@0,400;0,500;0,600;1,400;1,500&family=JetBrains+Mono:wght@400&family=Noto+Serif+SC:wght@400;500;600;700&family=Noto+Sans+SC:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <!-- Analytics -->
    {plausibleDomain && (
      <script defer data-domain={plausibleDomain} src="https://plausible.io/js/script.js" />
    )}
    {fathomSiteId && (
      <script src="https://cdn.usefathom.com/script.js" data-site={fathomSiteId} defer />
    )}
  </head>
  <body>
    <div class="page">
      <canvas id="mouse-trail" class="mouse-trail"></canvas>
      <Nav />
      <main id="main-content">
        <slot />
      </main>
      <Footer />
      <BackToTop />
      <div id="reading-progress" class="reading-progress" aria-hidden="true"></div>
    </div>
    <script>
      // Reading progress indicator
      const bar = document.getElementById('reading-progress');
      if (bar) {
        window.addEventListener('scroll', () => {
          const scrollTop = window.scrollY;
          const docHeight = document.documentElement.scrollHeight - window.innerHeight;
          const progress = docHeight > 0 ? Math.min(scrollTop / docHeight, 1) : 0;
          bar.style.transform = `scaleX(${progress})`;
        }, { passive: true });
      }
    </script>
    <script>
      // Mouse trail particle effect
      (function() {
        const canvas = document.getElementById('mouse-trail');
        if (!canvas) return;
        const ctx = canvas.getContext('2d');
        let points = [];
        let mouse = { x: -9999, y: -9999 };
        let animating = true;

        function resize() {
          canvas.width = window.innerWidth;
          canvas.height = window.innerHeight;
        }
        resize();
        window.addEventListener('resize', resize);

        function Point(x, y, sx, sy, size, alpha) {
          this.x = x; this.y = y;
          this.sx = sx; this.sy = sy;
          this.size = size;
          this.alpha = alpha;
          this.life = 1;
          this.active = true;
          this.update = function() {
            this.x += this.sx;
            this.y += this.sy;
            this.sy += 0.04;
            this.life -= 0.008;
            this.alpha = this.life * 0.6;
            if (this.life <= 0) { this.active = false; }
          };
          this.draw = function() {
            ctx.beginPath();
            ctx.arc(this.x, this.y, this.size * this.life, 0, Math.PI * 2);
            ctx.fillStyle = `rgba(217,119,6,${this.alpha})`;
            ctx.fill();
          };
        }

        function animate() {
          if (!animating) { requestAnimationFrame(animate); return; }
          ctx.clearRect(0, 0, canvas.width, canvas.height);

          for (let i = 0; i < 3; i++) {
            const angle = Math.random() * Math.PI * 2;
            const speed = 0.5 + Math.random() * 1.5;
            points.push(new Point(
              mouse.x + (Math.random() - 0.5) * 4,
              mouse.y + (Math.random() - 0.5) * 4,
              Math.cos(angle) * speed,
              Math.sin(angle) * speed - 1,
              2 + Math.random() * 3,
              0.3 + Math.random() * 0.4
            ));
          }

          points = points.filter(p => p.active);
          for (const p of points) { p.update(); p.draw(); }
          if (points.length > 300) points = points.slice(-300);

          requestAnimationFrame(animate);
        }

        const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (!prefersReduced) animate();

        document.addEventListener('mousemove', e => { mouse.x = e.clientX; mouse.y = e.clientY; });
        document.addEventListener('mouseleave', () => { mouse.x = -9999; mouse.y = -9999; });
      })();
    </script>
  </body>
</html>

<style>
  .mouse-trail {
    position: fixed;
    top: 0; left: 0;
    width: 100vw; height: 100vh;
    pointer-events: none;
    z-index: 9999;
  }
</style>
