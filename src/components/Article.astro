---
import Heading from "./Heading.astro";
import Prose from "./Prose.astro";

interface Heading_ {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  date: Date;
  updatedDate?: Date;
  description: string;
  tags?: string[];
  readingTime?: number;
  headings?: Heading_[];
  prevPost?: { id: string; title: string };
  nextPost?: { id: string; title: string };
}

const { title, date, updatedDate, description, tags = [], readingTime, headings = [], prevPost, nextPost } = Astro.props;

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const formattedUpdatedDate = updatedDate?.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<article class="article">
  <header class="article-header">
    <div class="article-bread">
      <a href="/">← 全部文章</a>
    </div>
    <Heading as="h1">{title}</Heading>
    <div class="article-meta-bar">
      <time datetime={date.toISOString()}>{formattedDate}</time>
      {readingTime && <span class="meta-dot">·</span>}
      {readingTime && <span class="reading-time">閱讀 {readingTime} 分鐘</span>}
    </div>
    {updatedDate && (
      <p class="article-updated">
        更新於 <time datetime={updatedDate.toISOString()}>{formattedUpdatedDate}</time>
      </p>
    )}
    {tags.length > 0 && (
      <div class="article-tags">
        {tags.map((tag) => (
          <a href={`/tags/${tag}`} class="tag">{tag}</a>
        ))}
      </div>
    )}
  </header>

  <Prose>
    <slot />
  </Prose>

  {(prevPost || nextPost) && (
    <nav class="post-nav" aria-label="Post navigation">
      <div class="post-nav-prev">
        {prevPost && (
          <a href={`/posts/${prevPost.id}`} class="post-nav-link">
            <span class="post-nav-label">← 較新文章</span>
            <span class="post-nav-title">{prevPost.title}</span>
          </a>
        )}
      </div>
      <div class="post-nav-next">
        {nextPost && (
          <a href={`/posts/${nextPost.id}`} class="post-nav-link post-nav-link--right">
            <span class="post-nav-label">較舊文章 →</span>
            <span class="post-nav-title">{nextPost.title}</span>
          </a>
        )}
      </div>
    </nav>
  )}
</article>

<style>
  .article {
    max-width: var(--width-content);
    padding-bottom: 3rem;
  }

  /* ─── Header ──────────────────────────── */
  .article-header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .article-bread {
    margin-bottom: 0.75rem;
  }
  .article-bread a {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--text-tertiary);
    text-decoration: none;
    transition: color 0.2s;
  }
  .article-bread a:hover {
    color: var(--accent);
  }

  .article-meta-bar {
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    color: var(--text-tertiary);
    margin-top: 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .meta-dot {
    color: var(--border);
  }

  .reading-time {
    color: var(--text-tertiary);
  }

  .article-updated {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--text-tertiary);
    font-style: italic;
    margin-top: 0.375rem;
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  /* ─── Tags ──────────────────────────────── */
  .tag {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
    background: var(--accent-subtle);
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    transition: all 0.2s;
    border: 1px solid transparent;
  }
  .tag:hover {
    color: var(--accent-hover);
    background: var(--accent-subtle);
    border-color: var(--accent);
    transform: translateY(-1px);
  }

  /* ─── Post Navigation ───────────────────── */
  .post-nav {
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .post-nav-prev,
  .post-nav-next {
    flex: 1;
  }

  .post-nav-next {
    text-align: right;
  }

  .post-nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    text-decoration: none;
    color: var(--text);
    padding: 1rem;
    border-radius: var(--radius-md);
    transition: background 0.2s;
  }
  .post-nav-link:hover {
    background: var(--surface-hover);
  }

  .post-nav-link--right {
    align-items: flex-end;
  }

  .post-nav-label {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--text-tertiary);
    transition: color 0.2s;
  }
  .post-nav-link:hover .post-nav-label {
    color: var(--accent);
  }

  .post-nav-title {
    font-family: var(--font-heading);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--text);
    line-height: 1.35;
    transition: color 0.2s;
  }
  .post-nav-link:hover .post-nav-title {
    background: var(--gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* ─── Responsive ────────────────────────── */
  @media (max-width: 600px) {
    .post-nav {
      flex-direction: column;
      gap: 1rem;
    }
    .post-nav-next {
      text-align: left;
    }
    .post-nav-link--right {
      align-items: flex-start;
    }
  }
</style>
